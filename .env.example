# Local database. Replace with libsql://... and set TURSO_AUTH_TOKEN in production.
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
CRON_SECRET=

# Used by the idempotent seed command.
OWNER_NAME=Founder
OWNER_EMAIL=founder@example.com
OWNER_PASSWORD=

# Public application URL used for email tracking pixels.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional. These may instead be configured in Settings → DeepSeek AI.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
