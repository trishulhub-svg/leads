# Local database. Replace with libsql://... and set TURSO_AUTH_TOKEN in production.
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# AUTH_SECRET signs login/session + unsubscribe/reset tokens.
AUTH_SECRET=
# CRON_SECRET authorizes Vercel Cron routes (required — cron fails closed without it).
CRON_SECRET=
# ENCRYPTION_KEY encrypts stored SMTP/IMAP passwords + AI keys at rest. Keep it
# SEPARATE from AUTH_SECRET so rotating one never breaks the other. If unset, the
# app falls back to AUTH_SECRET for backward compatibility (set this in production).
ENCRYPTION_KEY=

# Used by the idempotent seed command.
OWNER_NAME=Founder
OWNER_EMAIL=founder@example.com
OWNER_PASSWORD=

# Public application URL used for email tracking pixels.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional. These may instead be configured in Settings → DeepSeek AI.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
